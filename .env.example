# GitHub Personal Access Token with `repo` scope.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_replace_me

# Repository that will hold the plugin Releases.
# Format: owner/repo  (e.g. acme-corp/jetbrains-plugin-mirror)
GITHUB_REPO=your-org/your-repo

# --- Server-only options (only used by the `server` service) ---

# When "true", the server pre-downloads every plugin asset listed in
# plugins.json into a local volume on container start, and serves them from
# /plugins/<file>. IDEs never reach out to GitHub.
# When "false" (default), the served updatePlugins.xml points IDEs straight
# at the GitHub Release download URLs — no local storage needed.
LOCAL_CACHE=false

# Optional absolute base URL written into updatePlugins.xml when LOCAL_CACHE
# is on (e.g. http://plugins.intranet.acme.corp:8080).
# Leave empty to emit relative URLs (resolved by the IDE against the URL it
# fetched updatePlugins.xml from) — usually fine.
PUBLIC_BASE_URL=
